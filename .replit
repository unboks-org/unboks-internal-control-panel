run = "sh -c 'python -m pip install -r requirements.txt && python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8010}'"
entrypoint = "app/main.py"

[deployment]
run = ["sh", "-c", "python -m pip install -r requirements.txt && python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8010}"]

[env]
PYTHONUNBUFFERED = "1"
