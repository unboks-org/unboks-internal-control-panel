entrypoint = "app/main.py"
modules = ["python-3.11"]

[run]
args = ["sh", "-c", "python3 -m pip install -r requirements.txt && python3 -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8010}"]

[run.env]
PYTHONUNBUFFERED = "1"

[deployment]
run = ["sh", "-c", "python3 -m pip install -r requirements.txt && python3 -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8010}"]
deploymentTarget = "cloudrun"

[gitHubImport]
requiredFiles = [".replit"]
