entrypoint = "app/main.py"
modules = ["python-3.11"]

[run]
args = ["sh", "-c", "python3 -m venv .venv && . .venv/bin/activate && python -m pip install -r requirements.txt && python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8010}"]

[run.env]
PYTHONUNBUFFERED = "1"

[deployment]
run = ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
deploymentTarget = "autoscale"
build = ["pip", "install", "-r", "requirements.txt"]

[gitHubImport]
requiredFiles = [".replit"]

[agent]
expertMode = true

[[ports]]
localPort = 8010
externalPort = 80
