NR3_ENV=development
NR3_ADMIN_PASSWORD=change-me
NR3_SESSION_SECRET=change-me-to-a-long-random-value
NR3_DB_PATH=data/nr3.db
NR3_TENANTS_CLIENT_DIR=/root/clients
NR3_ALLOWED_IPS=127.0.0.1/32
NR3_BASE_URL=http://127.0.0.1:8010
NR3_EMAIL_FROM=onboarding@unboks.org
NR3_SMTP_HOST=
NR3_SMTP_PORT=587
NR3_SMTP_USERNAME=
NR3_SMTP_PASSWORD=
NR3_SMTP_USE_TLS=true
NR3_INTERNAL_API_TOKEN=change-me-to-a-long-random-bridge-token

# J3-BE-01: tenant discovery from client.json files at runtime.
# NR3_TENANTS_CLIENT_DIR is the in-container path the tenants loader
# will glob ({path}/*/config/client.json). Set to empty or unset to
# fall back to the hard-coded placeholder tenant list (useful for
# local dev without a tenant config tree).
NR3_TENANTS_CLIENT_DIR=/app/tenant_root
# Host-side path the docker-compose volume binds onto NR3_TENANTS_CLIENT_DIR.
# Default ./tenant_root for local dev; production typically /opt/wtyj/clients.
NR3_TENANTS_CLIENT_HOST_DIR=./tenant_root
